{
  "expo": {
    "name": "HappyHourApp",
    "slug": "happy-hour-app",
    "version": "1.0.0",
    "scheme": "diningdealz",
    "orientation": "portrait",
    "icon": "./assets/DiningDealz-Icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/DiningDealz-Logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#080101"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#080101",
        "foregroundImage": "./assets/DiningDealz-Icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/DiningDealz-Icon.png"
    }
  }
}
